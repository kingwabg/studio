{
  "name": "Document Studio",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:1-22-bookworm",

  // 4코어 최소 사양 — Vite HMR·rhwp WASM 체감 속도용.
  // 무료 코어시간(월 120)을 아끼려면 이 블록을 지우면 2코어로 열림.
  "hostRequirements": {
    "cpus": 4
  },

  // npm ci(root) → postinstall이 sync:rhwp로 /pkg(WASM)을 @rhwp/core에서 공급
  // → rhwp-studio 의존성 → Claude Code CLI 전역 설치 (터미널에서 `claude`로 시작)
  "postCreateCommand": "npm ci && npm ci --prefix rhwp-studio && npm i -g @anthropic-ai/claude-code",

  "postAttachCommand": "npx vite --host 0.0.0.0 --port 5175",
  "forwardPorts": [5175, 7700],
  "portsAttributes": {
    "5175": {
      "label": "Document Studio",
      "onAutoForward": "openBrowser"
    },
    "7700": {
      "label": "rhwp 캔버스 한컴 (npm run dev:rhwp)",
      "onAutoForward": "notify"
    }
  },

  // AI 패널(MiniMax) 키는 Codespaces Secret `MINIMAX_API_KEY` 로 주입하세요:
  // GitHub → Settings → Codespaces → New secret → 이름 MINIMAX_API_KEY, repo 접근 kingwabg/studio.
  // vite 프록시가 process.env 를 우선 읽으므로 .env.local 파일 없이 바로 동작합니다.

  "customizations": {
    "vscode": {
      "extensions": [
        "bradlc.vscode-tailwindcss",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
